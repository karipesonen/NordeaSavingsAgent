{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Education/Risk Lesson Agent Contract",
  "description": "Structured contract for Nora's education and risk lesson sub-agent.",
  "input_schema": {
    "type": "object",
    "required": ["user_id"],
    "properties": {
      "user_id": { "type": "string" },
      "current_blocker": {
        "type": ["string", "null"],
        "enum": ["risk", "confusion", "amount_feels_too_small", "not_getting_around_to_it", null]
      },
      "risk_comfort": { "type": ["string", "null"], "enum": ["low", "medium", "high", null] },
      "preferred_format": {
        "type": ["string", "null"],
        "enum": ["article", "podcast", "quiz", "short_card", "video", null]
      },
      "goal_plan": { "type": "object" },
      "user_memory": { "type": "object" }
    }
  },
  "output_schema": {
    "type": "object",
    "required": [
      "agent",
      "topic",
      "format",
      "estimated_duration_seconds",
      "lesson_card",
      "check_questions",
      "next_topic",
      "resource_stub",
      "memory_updates",
      "safety_flags"
    ],
    "properties": {
      "agent": { "const": "education_risk_lesson" },
      "topic": { "type": "string" },
      "format": { "type": "string" },
      "estimated_duration_seconds": { "type": "integer" },
      "blocker": { "type": "string" },
      "lesson_card": {
        "type": "object",
        "required": ["title", "plain_answer", "key_points", "future_self_prompt"]
      },
      "check_questions": {
        "type": "array",
        "minItems": 1,
        "maxItems": 2
      },
      "next_topic": { "type": "string" },
      "resource_stub": { "type": "object" },
      "memory_updates": { "type": "array" },
      "safety_flags": { "type": "array" }
    }
  }
}
